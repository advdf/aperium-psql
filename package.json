{
  "name": "aperium-psql",
  "productName": "Aperium PSQL",
  "version": "0.1.0",
  "description": "A clean PostgreSQL UI with real psql terminal, served as a web app",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --outfile=dist/renderer.bundle.js --platform=browser --format=iife --target=chrome120",
    "start": "npm run build && node server/index.js",
    "serve": "node server/index.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "argon2": "^0.40.0",
    "codemirror": "^6.0.2",
    "connect-pg-simple": "^9.0.0",
    "cookie-parser": "^1.4.0",
    "esbuild": "^0.28.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "js-yaml": "^4.1.0",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.0.0",
    "pg": "^8.13.0",
    "ssh2": "^1.15.0",
    "ws": "^8.18.0"
  }
}
